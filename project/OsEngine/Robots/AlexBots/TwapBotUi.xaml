<Window x:Class="OsEngine.Robots.AlexBots.TwapBotUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OsEngine.Robots.AlexBots"
        mc:Ignorable="d"
            Title="Twap Order Create" Height="650" Width="411" MinWidth="450" MinHeight="700" Icon="/Images/OsLogo.ico" Style="{StaticResource WindowStyleCanResize}" ResizeMode="CanResize" WindowStartupLocation="CenterScreen" >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="77*"/>
            <ColumnDefinition Width="75*"/>
            <ColumnDefinition Width="75*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Rectangle Grid.Row="0"  Margin="2,2,2,0" Grid.ColumnSpan="3"/>
        <Button Grid.Row="0" Content="Покупка" Margin="5,24,6,0" VerticalAlignment="Top" Height="25" Name="ButtonBuy" Click="ButtonBuy_Click"/>
        <Button Grid.Row="0" Content="Продажа" Margin="2,24,3,0" VerticalAlignment="Top" Grid.Column="2" Height="25" Name="ButtonSell" Click="ButtonSell_Click"/>

        <Label Grid.Row="0" Grid.Column="1" Content="Время сервера" VerticalAlignment="Top" HorizontalAlignment="Center" />
        <Label Grid.Row="0" Grid.Column="1" Content="UTC (+ ч.):" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="3" HorizontalAlignment="Left" VerticalAlignment="Center" Width="50" Margin="70,0,0,0" Name="TimeShiftTextBox"/>

        <Label Grid.Row="0" Grid.Column="1" Content="Ч:" HorizontalAlignment="Left" Margin="5,0,0,5" VerticalAlignment="Bottom" Height="22" Width="19"/>
        <TextBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Margin="25,30,0,5" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="22" Name="HourCurrentTimeTextBox"/>
        <Label Grid.Row="0"  Grid.Column="1" Content="М:" HorizontalAlignment="Left" Margin="50,0,0,5" VerticalAlignment="Bottom" Height="22" Width="22"/>
        <TextBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Margin="75,0,0,5" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="22" Name="MinuteCurrentTimeTextBox"/>
        <Label Grid.Row="0" Grid.Column="1" Content="С:" HorizontalAlignment="Left" Margin="100,0,0,5" VerticalAlignment="Bottom" Height="22" Width="19"/>
        <TextBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Margin="120,0,0,5" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="22" Name="SecondCurrentTimeTextBox"/>

        <Rectangle Grid.Row="1"  Margin="2,2,2,0" Grid.ColumnSpan="3"/>
        <Label Grid.Row="1" Content="Цена" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="23" Width="38"/>
        <Label Grid.Row="1" Content="Тип ограничения" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Grid.Column="1" Height="23" Width="110"/>
        <Label Grid.Row="1" Content="Ограничение цены" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Grid.Column="2" Height="23" Width="124"/>
        <TextBox Grid.Row="1" Margin="10,30,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Name="PriceRestrictionTextBox"/>
        <ComboBox Grid.Row="1" Grid.Column="1" Margin="10,30,10,0" VerticalAlignment="Top" Name="TypeRestrictionComboBox"/>
        <TextBox Grid.Row="1" Margin="8,30,8,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="2" Name="SlipageTextBox"/>
        <CheckBox Grid.Row="1" Content="Рыночная" HorizontalAlignment="Left" Margin="10,55,0,0" VerticalAlignment="Top" Name="MarketCheckBox"/>

        <Rectangle Grid.Row="2" Margin="2,2,2,0" Stroke="Black" Grid.ColumnSpan="3"   />
        <Label Grid.Row="2" Content="Кол-во/Объём" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116"/>
        <Label Grid.Row="2" Content="Кол-во (лот 1000)" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116" Grid.Column="1"/>
        <Label Grid.Row="2" Content="Объём" HorizontalAlignment="Left" Margin="8,5,0,0" VerticalAlignment="Top" Height="22" Width="116" Grid.Column="2"/>

        <Label Grid.Row="2" Content="Диапазон объема (%):" HorizontalAlignment="Left" Margin="5,60,0,0" VerticalAlignment="Top" Height="22" Width="156" Grid.Column="0"/>
        <TextBox Grid.Row="2" Margin="10,60,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="1" Name="VolumeRangeTextBox"/>

        <ComboBox Grid.Row="2" Margin="10,30,10,0" VerticalAlignment="Top" Name="TypeVolumeComboBox"/>
        <TextBox Grid.Row="2" Margin="10,30,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="1" Name="QuantityTextBox"/>
        <TextBox Grid.Row="2" Margin="10,30,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="2" Name="VolumeTextBox"/>

        <Rectangle Grid.Row="3" Margin="2,2,2,0" Stroke="Black" Grid.ColumnSpan="3"   />
        <Label Grid.Row="3" Content="Время старта" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="31,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Name="HourStartTextBox"/>
        <Label Grid.Row="3" Content="Ч:" HorizontalAlignment="Left" Margin="10,30,0,0" VerticalAlignment="Top" Height="22" Width="19"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="74,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Name="MinuteStartTextBox"/>
        <Label Grid.Row="3"  Content="М:" HorizontalAlignment="Left" Margin="51,30,0,0" VerticalAlignment="Top" Height="22" Width="22"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="113,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Name="SecondStartTextBox"/>
        <Label Grid.Row="3" Content="С:" HorizontalAlignment="Left" Margin="92,30,0,0" VerticalAlignment="Top" Height="22" Width="19"/>
        <CheckBox Grid.Row="3" Grid.Column="1" Content="С текущего времени" HorizontalAlignment="Center" Margin="0,30,0,0" VerticalAlignment="Top" Width="139" Name="CurrentTimeCheckBox"/>
        <Label Grid.Row="3" Content="Время окончания" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116" Grid.Column="2"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="31,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Grid.Column="2" Name="HourEndTextBox"/>
        <Label Grid.Row="3" Content="Ч:" HorizontalAlignment="Left" Margin="10,30,0,0" VerticalAlignment="Top" Height="22" Width="19" Grid.Column="2"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="74,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Grid.Column="2" Name="MinuteEndTextBox"/>
        <Label Grid.Row="3" Content="М:" HorizontalAlignment="Left" Margin="51,30,0,0" VerticalAlignment="Top" Height="22" Width="22" Grid.Column="2"/>
        <TextBox Grid.Row="3" HorizontalAlignment="Left" Margin="113,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="22" Grid.Column="2" Name="SecondEndTextBox"/>
        <Label Grid.Row="3" Content="С:" HorizontalAlignment="Left" Margin="92,30,0,0" VerticalAlignment="Top" Height="22" Width="19" Grid.Column="2"/>

        <Rectangle Grid.Row="4" Margin="2,2,2,0" Stroke="Black" Grid.ColumnSpan="3"   />
        <Label Grid.Row="4" Content="Парам. интервала" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116"/>
        <Label Grid.Row="4" Content="Кол-во итераций" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116" Grid.Column="1"/>
        <Label Grid.Row="4" Content="Время итер., сек." HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Height="22" Width="116" Grid.Column="2"/>

        <ComboBox Grid.Row="4" Margin="10,30,10,0" VerticalAlignment="Top" Name="IntervalParametersComboBox"/>
        <TextBox Grid.Row="4" Margin="10,30,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="1" Name="QuantityIterationsTextBox"/>
        <TextBox Grid.Row="4" Margin="10,30,10,0" TextWrapping="Wrap" VerticalAlignment="Top" Grid.Column="2" Name="IterationTimeTextBox"/>

        <Rectangle Grid.Row="5" Margin="2,2,2,0" Stroke="Black" Grid.ColumnSpan="3"   />
        <Button Grid.Row="5" Content="Старт" Margin="5,30,6,0" VerticalAlignment="Top" Height="25" Click="ButtonStart_Click">
            <Button.Background>
                <RadialGradientBrush GradientOrigin="0.5,0.5">
                    <GradientStop Color="#FF111217" Offset="1"/>
                    <GradientStop Color="#FF1F6A41" Offset="0.082"/>
                </RadialGradientBrush>
            </Button.Background>
        </Button>

        <Button Grid.Row="5" Content="Пауза" Margin="2,30,3,0" VerticalAlignment="Top" Grid.Column="2" Height="25" Click="ButtonPause_Click">
            <Button.Background>
                <RadialGradientBrush GradientOrigin="0.5,0.5">
                    <GradientStop Color="#FF111217" Offset="1"/>
                    <GradientStop Color="#B8860B" Offset="0.082"/>
                </RadialGradientBrush>
            </Button.Background>
        </Button>

        <Button Grid.Row="5" Content="Отмена" Margin="2,60,3,0" VerticalAlignment="Top" Grid.Column="2" Height="25" Click="ButtonCancel_Click">
            <Button.Background>
                <RadialGradientBrush GradientOrigin="0.5,0.5">
                    <GradientStop Color="#FF111217" Offset="1"/>
                    <GradientStop Color="#FF753444" Offset="0.082"/>
                </RadialGradientBrush>
            </Button.Background>
        </Button>

        <Button Grid.Row="5" Content="Таблица ордеров" Margin="2,58,3,0" VerticalAlignment="Top" Grid.Column="1" Height="25" Click="ButtonOrderTable_Click" />

        <Label Content="Текущий режим" Grid.Row="5" Margin="2,5,3,0" VerticalAlignment="Top" Grid.Column="1" Height="25" />
        <TextBox Name="CurrentModeTextBox" Grid.Row="5" Margin="2,30,3,0" VerticalAlignment="Top" Grid.Column="1" Height="25" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

        <Rectangle Grid.Row="6" Margin="2,2,2,0" Stroke="Black" Grid.ColumnSpan="3"   />
        <CheckBox Grid.Row="6" Content="Оповещать об исполнении связанных заявок" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Grid.ColumnSpan="2" Width="284" Name="UseLogCheckBox" />
    </Grid>
</Window>
