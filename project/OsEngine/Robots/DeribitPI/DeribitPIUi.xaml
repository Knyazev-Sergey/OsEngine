<Window x:Class="OsEngine.Robots.DeribitPI.DeribitPIUi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeribitPI" Height="600" Width="600" Icon="/Images/OsLogo.ico" Style="{StaticResource WindowStyleNoResize}" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Topmost="True">
    <Grid>
        <Rectangle Margin="5,5,5,37"/>
        <Label Name="LabelRegime" Content="Режим работы" HorizontalAlignment="Left" Margin="40,21,0,0" VerticalAlignment="Top" Foreground="Gainsboro" FontSize="14" />
        <ComboBox Name="ComboBoxRegime" Margin="149,21,40,0" VerticalAlignment="Top"/>

        <GroupBox Header="Настройка опционной конструкции" Margin="5,60,305,392" Foreground="Gainsboro" FontSize="12" >
            <UniformGrid Rows="3" Columns="2">
                <TextBlock Margin="5" Height="20" VerticalAlignment="Center">% от депозита</TextBlock>
                <TextBox Margin="5"></TextBox>
                <TextBlock Margin="5" Height="20" VerticalAlignment="Center">Кол-во итераций</TextBlock>
                <TextBox Margin="5"></TextBox>
                <TextBlock Margin="5" Height="32" TextWrapping="Wrap">Время до экспирации для разбора конструкции</TextBlock>
                <TextBox Margin="5"></TextBox>

            </UniformGrid>
        </GroupBox>
        <GroupBox Header="Настройка внутредневной торговли" Margin="305,60,5,247" Foreground="Gainsboro" FontSize="12" >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="35*"></RowDefinition>
                    <RowDefinition Height="35*"></RowDefinition>
                    <RowDefinition Height="35*"></RowDefinition>
                    <RowDefinition Height="163*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="63*"></ColumnDefinition>
                    <ColumnDefinition Width="29*"></ColumnDefinition>

                </Grid.ColumnDefinitions>
                <TextBlock Margin="5,0,5,0" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" Height="23">Кол-во частей рабочей части</TextBlock>
                <TextBox Margin="5,0,5,0" Grid.Column="1" VerticalAlignment="Center" Height="23"/>
                <TextBlock Margin="5,0,5,0" Grid.Row="1" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" Height="23">Коэф расчета рабочей части</TextBlock>
                <TextBox Margin="5,0,5,0" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Height="23"></TextBox>
                <TextBlock Margin="5,0,5,0" Height="23" TextWrapping="Wrap" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center">Увеличение рабочей части</TextBlock>
                <TextBox Margin="5,0,5,0" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Height="23"></TextBox>
                <GroupBox Header="Увеличение рабочей части" Foreground="Gainsboro" FontSize="12" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                    <TextBlock Margin="5,0,5,0" Grid.Column="0" TextWrapping="Wrap" VerticalAlignment="Center" Height="23">Кол-во частей рабочей части</TextBlock>
                 
                </GroupBox>
            </Grid>

        </GroupBox>

        <Button Name="ButtonAccept" Content="Accept" HorizontalAlignment="Right" Margin="0,0,5,10" VerticalAlignment="Bottom" Width="120" Click="Button_Click"/>

    </Grid>
</Window>